rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation Blueprint for PajskDataEntry
    function isValidPajskDataEntry(data) {
      return data.keys().hasAll(['tahun', 'aliran', 'jumlahPelajar', 'gredA', 'gredB', 'gredC', 'gredD', 'gredE', 'gredTL', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 11 &&
             data.tahun is number &&
             data.aliran is string && data.aliran.size() <= 100 && data.aliran.size() > 0 &&
             data.jumlahPelajar is number &&
             data.gredA is number &&
             data.gredB is number &&
             data.gredC is number &&
             data.gredD is number &&
             data.gredE is number &&
             data.gredTL is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /shared_pajsk_data/{pajskDataId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
